# ------------------------------------------------------------------
# Envoi des demandes de rendez-vous par e-mail (formulaire du site)
# Copier ce fichier en `.env.local` et remplir avec un vrai compte SMTP
# (Infomaniak, Gmail avec mot de passe d'application, Resend SMTP, etc.)
# Sans configuration, le formulaire propose automatiquement un repli
# e-mail pré-rempli / WhatsApp au visiteur.
# ------------------------------------------------------------------

SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@clinicglobalestheticgeneva.ch
SMTP_PASS=motdepasse

# Destinataire des demandes (défaut : contact@clinicglobalestheticgeneva.ch)
RESERVATION_TO=contact@clinicglobalestheticgeneva.ch
# Expéditeur affiché (défaut : SMTP_USER)
RESERVATION_FROM=contact@clinicglobalestheticgeneva.ch

# URL publique du site (SEO : sitemap, canonique, Open Graph)
NEXT_PUBLIC_SITE_URL=https://clinicglobalestheticgeneva.ch
