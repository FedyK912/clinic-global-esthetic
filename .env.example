# ------------------------------------------------------------------
# Configuration de production — globalaesthetic.ch (Infomaniak)
# Copier ce fichier en `.env.local` SUR LE SERVEUR et remplir avec les
# identifiants réels. Ne jamais committer `.env.local`.
# ------------------------------------------------------------------

# URL publique du site (SEO : sitemap, canoniques, Open Graph)
NEXT_PUBLIC_SITE_URL=https://globalaesthetic.ch

# Envoi des demandes de rendez-vous par e-mail (formulaire du site).
# Utiliser une adresse créée dans le Service Mail Infomaniak du domaine,
# par ex. contact@globalaesthetic.ch, avec son mot de passe.
# Sans configuration, le formulaire propose automatiquement un repli
# e-mail pré-rempli / WhatsApp au visiteur — aucune demande n'est perdue.
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@globalaesthetic.ch
SMTP_PASS=motdepasse-de-la-boite-mail

# Destinataire des demandes (la boîte que la clinique consulte)
RESERVATION_TO=contact@globalaesthetic.ch
# Expéditeur affiché (défaut : SMTP_USER)
RESERVATION_FROM=contact@globalaesthetic.ch
